{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "crons": [
    { "path": "/api/cron/collect",  "schedule": "0 */4 * * *"  },
    { "path": "/api/cron/enrich",   "schedule": "30 */4 * * *" },
    { "path": "/api/cron/events",   "schedule": "45 */4 * * *" },
    { "path": "/api/cron/momentum", "schedule": "0 2 * * *"    },
    { "path": "/api/cron/reports",  "schedule": "0 6 * * *"    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ]
}
