# ============================================================
# AIscentra Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── OpenRouter ───────────────────────────────────────────────
# Get from: https://openrouter.ai/keys
# Used by: Signal Engine, Event Generator, Content Agent, Assistant
OPENROUTER_API_KEY=sk-or-your-key-here

# Model to use for signal enrichment — pinned for scoring consistency
# Signal Scoring Specification v1.0: temperature=0, model pinned
OPENROUTER_MODEL=anthropic/claude-3-haiku

# ── Application ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment: development | production
NODE_ENV=development

# ── Admin ────────────────────────────────────────────────────
# Email address allowed to access the admin interface
# Readiness Assessment Blocker B-02: admin auth must be defined before Stage 2
ADMIN_EMAIL=admin@aiscentra.com
